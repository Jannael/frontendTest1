---
import Layout from '@/layouts/layout.astro'
import Header from '@/components/header.astro'
import Navbar from '@/components/navbar.astro'
import Search from '@/components/search-input.tsx'
import OrderList from '@/components/order-list.tsx'
import { getAllOrders } from '@/api/get-all-orders'

let orders = []
try {
	orders = await getAllOrders()
} catch (error) {
	console.error('Failed to fetch orders:', error)
}

const navbarItems = [
	{ text: 'Upcoming', isActive: true, href: '/' },
	{ text: 'Completed', isActive: false, href: '/' },
	{ text: 'Past', isActive: false, href: '/' },
]
---

<Layout title="Home">
	<Header title="Cargo Orders" returnUrl="/" />
	<Navbar items={navbarItems} />
	<Search client:only="react" />
	<OrderList orders={orders} client:only="react" />
</Layout>
