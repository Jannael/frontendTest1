---
import Layout from '@/layouts/layout.astro'
import Header from '@/components/header.astro'
import Navbar from '@/components/navbar.astro'
import Search from '@/components/search.astro'
import { getAllOrders } from '@/api/get-all-orders'

const orders = await getAllOrders()

const navbarItems = [
	{ text: 'Upcoming', isActive: true, href: '/' },
	{ text: 'Completed', isActive: false, href: '/' },
	{ text: 'Past', isActive: false, href: '/' },
]
---

<Layout title="Home">
	<Header title="Cargo Orders" returnUrl="/" />
	<Navbar items={navbarItems} />
	<Search />
	<script define:vars={{ orders }}>
		import { useOrdersStore } from '@/stores/orders'
		useOrdersStore.getState().setAllOrders(orders)
	</script>
</Layout>
