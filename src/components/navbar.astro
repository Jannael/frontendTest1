---
interface NavItem {
	text: string
	isActive: boolean
	href: string
}

interface Props {
	items: NavItem[]
}

const { items } = Astro.props
---

<nav class="mt-[18px] flex w-full items-center justify-stretch gap-6 px-[39px]">
	{
		items.map((item) => (
			<a
				href={item.href}
				class={`relative flex w-1/3 max-w-100 flex-col items-center text-center text-[18px] font-extrabold ${item.isActive ? 'text-primary' : 'text-txt'}`}
			>
				<span class="font-avenir">{item.text}</span>
				{item.isActive && <span class="bg-primary absolute top-[calc(100%+5px)] left-2 h-[2px] w-3/20" />}
			</a>
		))
	}
</nav>
